about={\rtf1\ansi\ansicpg1251\deff0{\fonttbl{\f0\fnil\fcharset204 Impact;}{\f1\fnil Impact;}{\f2\fnil\fcharset0 Impact;}{\f3\fnil Arial;}{\f4\fnil\fcharset204{\*\fname Arial;}Arial CYR;}{\f5\fswiss\fcharset204{\*\fname Arial;}Arial CYR;}} {\colortbl ;\red0\green0\blue0;\red144\green60\blue57;\red155\green187\blue89;\red127\green127\blue127;\red0\green0\blue255;} {\*\generator Msftedit 5.41.15.1515;}\viewkind4\uc1\pard\cf1\lang1049\f0\fs18\'c1\'e8\'e1\'eb\'e5\'e9\'f1\'ea\'e8\'e9\lang0\f1  \lang1049\f0\'ec\'ee\'e4\'f3\'eb\'fc\lang0\f1  \lang1049\f0\'e4\'eb\'ff\lang0\f1  \lang1049\f0\'ef\'f0\'ee\'e3\'f0\'e0\'ec\'ec\'fb\lang0\f1  \cf2 TheWord -\cf1  \lang1049\f0\'ca\'ed\'e8\'e3\'e8\lang0\f1  \cf3\lang1049\f0\'cd\'ee\'e2\'ee\'e3\'ee\cf1\lang0\f1  \lang1049\f0\'c7\'e0\'e2\'e5\'f2\'e0\lang0\f1\par \fs32 ''\lang1049\f0\'cf\'e5\'f0\'e5\'e2\'ee\'e4\lang0\f1  \lang1049\f0\'e5\'ef\'e8\'f1\'ea\'ee\'ef\'e0\lang0\f1  \lang1049\f0\'ca\'e0\'f1\'f1\'e8\'e0\'ed\'e0\lang0\f1 ''\cf4\fs24  (\lang1049\f0\'cf\'e5\'ca\lang0\f1  1970)\par ''A Bishop Kassian Translation Of New Testament Books'' (TbK 1970)\par \cf1\lang1033\f2\fs18\'a9\lang0\f1  \lang1049\f0\'ef\'f0\'e0\'e2\'ee\'ee\'e1\'eb\'e0\'e4\'e0\'f2\'e5\'eb\'fc\lang0\f1  \lang1049\f0\'ed\'e5\lang0\f1  \lang1049\f0\'ed\'e0\'e9\'e4\'e5\'ed\lang0\f1\par \b\f3\fs16  \par  \par \lang1049\f4\'c0\'e2\'f2\'ee\'f0\lang0\f3  \lang1049\f4\'ec\'ee\'e4\'f3\'eb\'ff\lang0\f3 : \lang1049\f4\'c3\'e0\'f0\'e8\'ef\'ee\'e2\lang0\f3  \lang1049\f4\'d2\lang0\f3 .\lang1049\f4\'cc\lang0\f3 .\b0  (Timur_75 \lang1049\f4\'ec\'ee\'e4\'e5\'f0\'e0\'f2\'ee\'f0\lang0\f3  \lang1049\f4\'ee\'f4\'e8\'f6\'e8\'e0\'eb\'fc\'ed\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'f0\'f3\'f1\'f1\'ea\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'ef\'ee\'e4\'f4\'ee\'f0\'f3\'ec\'e0\lang0\f3  TheWord).\par \b Forum Profile: \cf5\b0 http://forum.theword.net/memberlist.php?mode=viewprofile&u=1686\cf1\par \lang1049\b\f4\'c8\'f1\'f2\'ee\'f7\'ed\'e8\'ea\lang0\f3  \lang1049\f4\'f2\'e5\'ea\'f1\'f2\'e0\lang0\f3 :\b0  "\lang1049\f4\'c8\'e7\'e4\'e0\'f2\'e5\'eb\'fc\'f1\'f2\'e2\'ee\lang0\f3  \lang1049\f4\'c1\'e8\'e1\'eb\'e5\'e8\'f1\'f2\lang0\f3 ": \cf5 http://www.bibleist.ru/biblio.php?q=001\cf1\par \lang1049\b\f4\'ce\'ef\'e8\'f1\'e0\'ed\'e8\'e5\lang0\f3  \lang1049\f4\'e2\'e7\'ff\'f2\'ee\lang0\f3  \lang1049\f4\'e8\'e7\lang0\f3 : \cf5\b0 http://www.superbook.org/CAS/cas.htm\cf1  \lang1049\f4\'e8\lang0\f3  \lang1049\f4\'c2\'e8\'ea\'e8\'ef\'e5\'e4\'e8\'e8\lang0\f3\par \fs20\par \lang1049\b\f4\fs16\'c0\'e2\'f2\'ee\'f0\lang0\f3 : \lang1049\f4\'d1\'e5\'f0\'e3\'e5\'e9\lang0\f3  \lang1049\f4\'d1\'e5\'f0\'e3\'e5\'e5\'e2\'e8\'f7\lang0\f3  \lang1049\f4\'c1\'e5\'e7\'ee\'e1\'f0\'e0\'e7\'ee\'e2\lang0\f3 ;\b0  29 \lang1049\f4\'f4\'e5\'e2\'f0\'e0\'eb\'ff\lang0\f3  1892, \lang1049\f4\'d1\'e0\'ed\'ea\'f2\lang0\f3 -\lang1049\f4\'cf\'e5\'f2\'e5\'f0\'e1\'f3\'f0\'e3\lang0\f3  \emdash  4 \lang1049\f4\'f4\'e5\'e2\'f0\'e0\'eb\'ff\lang0\f3  1965, \lang1049\f4\'cf\'e0\'f0\'e8\'e6\lang0\f3 . \lang1049\f4\'c5\'ef\'e8\'f1\'ea\'ee\'ef\lang0\f3  \lang1049\f4\'ca\'e0\'f2\'e0\'ed\'f1\'ea\'e8\'e9\lang0\f3  (\lang1049\f4\'e2\lang0\f3  \lang1049\f4\'fe\'f0\'e8\'f1\'e4\'e8\'ea\'f6\'e8\'e8\lang0\f3  \lang1049\f4\'ca\'ee\'ed\'f1\'f2\'e0\'ed\'f2\'e8\'ed\'ee\'ef\'ee\'eb\'fc\'f1\'ea\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'ef\'e0\'f2\'f0\'e8\'e0\'f0\'f5\'e0\'f2\'e0\lang0\f3 ), \lang1049\f4\'e1\'ee\'e3\'ee\'f1\'eb\'ee\'e2\lang0\f3 , \lang1049\f4\'fd\'ea\'e7\'e5\'e3\'e5\'f2\lang0\f3 .\par \par \lang1049\f4\'cd\'e0\'f1\'f2\'ee\'ff\'f9\'e8\'e9\lang0\f3  \lang1049\f4\'ef\'e5\'f0\'e5\'e2\'ee\'e4\lang0\f3  \lang1049\f4\'cd\'ee\'e2\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'c7\'e0\'e2\'e5\'f2\'e0\lang0\f3  \lang1049\f4\'e1\'fb\'eb\lang0\f3  \lang1049\f4\'ed\'e0\'f7\'e0\'f2\lang0\f3  \lang1049\f4\'e2\lang0\f3  1953 \lang1049\f4\'e3\'ee\'e4\'f3\lang0\f3 , \lang1049\f4\'ef\'f0\'e8\lang0\f3  \lang1049\f4\'ef\'ee\'e4\'e4\'e5\'f0\'e6\'ea\'e5\lang0\f3  \lang1049\f4\'c1\'f0\'e8\'f2\'e0\'ed\'f1\'ea\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'e8\lang0\f3  \lang1049\f4\'c8\'ed\'ee\'f1\'f2\'f0\'e0\'ed\'ed\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'c1\'e8\'e1\'eb\'e5\'e9\'f1\'ea\'ee\'e3\'ee\lang0\f3  \lang1049\f4\'ce\'e1\'f9\'e5\'f1\'f2\'e2\'e0\lang0\f3 , \lang1049\f4\'e3\'f0\'f3\'ef\'ef\'ee\'e9\lang0\f3  \lang1049\f4\'ef\'e5\'f0\'e5\'e2\'ee\'e4\'f7\'e8\'ea\'ee\'e2\lang0\f3 , \lang1049\f4\'ea\'ee\'f2\'ee\'f0\'ee\'e9\lang0\f3  \lang1049\f4\'f0\'f3\'ea\'ee\'e2\'ee\'e4\'e8\'eb\lang0\f3  \lang1049\f4\'e8\'e7\'e2\'e5\'f1\'f2\'ed\'fb\'e9\lang0\f3  \lang1049\f4\'f0\'f3\'f1\'f1\'ea\'e8\'e9\lang0\f3  \lang1049\f4\'e1\'e8\'e1\'eb\'e5\'e8\'f1\'f2\lang0\f3  \lang1049\f4\'e5\'ef\'e8\'f1\'ea\'ee\'ef\lang0\f3  \lang1049\f4\'ca\'e0\'f1\'f1\'e8\'e0\'ed\lang0\f3  (\lang1049\f4\'c1\'e5\'e7\'ee\'e1\'f0\'e0\'e7\'ee\'e2\lang0\f3 ; 1892-1965). \lang1049\f4\'c2\lang0\f3  \lang1049\f4\'ed\'e5\'e5\lang0\f3  \lang1049\f4\'f2\'e0\'ea\'e6\'e5\lang0\f3  \lang1049\f4\'e2\'f5\'ee\'e4\'e8\'eb\'e8\lang0\f3  \lang1049\f4\'ef\'f0\'ee\'f2\'ee\'e8\'e5\'f0\'e5\'e9\lang0\f3  \lang1049\f4\'cd\'e8\'ea\'ee\'eb\'e0\'e9\lang0\f3  \lang1049\f4\'ca\'f3\'eb\'ee\'ec\'e7\'e8\'ed\lang0\f3 , \lang1049\f4\'e1\'e0\'ef\'f2\'e8\'f1\'f2\'f1\'ea\'e8\'e9\lang0\f3  \lang1049\f4\'ef\'e0\'f1\'f2\'ee\'f0\lang0\f3  \lang1049\f4\'c0\lang0\f3 .\lang1049\f4\'c2\'e0\'f1\'e8\'eb\'fc\'e5\'e2\lang0\f3  \lang1049\f4\'e8\lang0\f3  \lang1049\f4\'e8\'f5\lang0\f3  \lang1049\f4\'f3\'f7\'e5\'ed\'e8\'ea\'e8\lang0\f3 . \lang1049\f4\'cf\'e8\'f1\'e0\'f2\'e5\'eb\'fc\lang0\f3  \lang1049\f4\'c1\'ee\'f0\'e8\'f1\lang0\f3  \lang1049\f4\'c7\'e0\'e9\'f6\'e5\'e2\lang0\f3  \lang1049\f4\'ef\'f0\'e8\'ed\'e8\'ec\'e0\'eb\lang0\f3  \lang1049\f4\'f3\'f7\'e0\'f1\'f2\'e8\'e5\lang0\f3  \lang1049\f4\'e2\lang0\f3  \lang1049\f4\'eb\'e8\'f2\'e5\'f0\'e0\'f2\'f3\'f0\'ed\'ee\'e9\lang0\f3  \lang1049\f4\'f0\'e5\'e4\'e0\'ea\'f6\'e8\'e8\lang0\f3  \lang1049\f4\'f2\'e5\'ea\'f1\'f2\'e0\lang0\f3 .\par \par \lang1049\f4\'cf\'e5\'f0\'e2\'ee\'ed\'e0\'f7\'e0\'eb\'fc\'ed\'ee\lang0\f3  \lang1049\f4\'e2\lang0\f3  \lang1049\f4\'ca\'ee\'ec\'e8\'f1\'f1\'e8\